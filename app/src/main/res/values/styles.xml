<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- A selectable row: tappable LinearLayout with label + optional orange dot. -->
    <style name="RowStyle">
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">42dp</item>
        <item name="android:paddingHorizontal">18dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?android:attr/selectableItemBackground</item>
    </style>

    <style name="RowLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.06</item>
    </style>

    <style name="RowSpacer">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_weight">1</item>
    </style>

    <!-- Empty 10dp slot reserved for the orange dot; visibility toggled in code. -->
    <style name="RowDot">
        <item name="android:layout_width">10dp</item>
        <item name="android:layout_height">10dp</item>
        <item name="android:background">@drawable/orange_dot</item>
        <item name="android:visibility">invisible</item>
    </style>

    <style name="Hairline">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginHorizontal">18dp</item>
        <item name="android:background">@color/hairline</item>
    </style>
</resources>
